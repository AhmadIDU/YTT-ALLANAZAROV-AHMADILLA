# ============================================================
# PossKassa — Muhit o'zgaruvchilari namunasi
# .env.example dan nusxa oling: cp .env.example .env
# ============================================================

# ─── Ma'lumotlar bazasi ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://posskassa:secret123@postgres:5432/posskassa
DB_ECHO=false

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://posskassa:secret123@rabbitmq:5672/

# ─── MinIO / S3 ───────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=posskassa

# ─── Keycloak ─────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=posskassa
KEYCLOAK_CLIENT_ID=posskassa-api
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION

# ─── O'zbekiston integratsiyalari ─────────────────────────
OFD_API_URL=https://ofd.soliq.uz/api
OFD_TOKEN=

DIDOX_API_URL=https://api.didox.uz/v1
DIDOX_TOKEN=

EIMZO_API_URL=https://eimzo.uz/api

ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ─── Claude Vision (Intake moduli) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ─── Ilova ────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=CHANGE_ME_32_CHARS_MIN_IN_PRODUCTION
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── PostgreSQL (Docker Compose) ──────────────────────────
POSTGRES_USER=posskassa
POSTGRES_PASSWORD=secret123
POSTGRES_DB=posskassa

# ─── Keycloak Admin (Docker Compose) ─────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
